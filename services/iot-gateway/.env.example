PORT=13100
NODE_ENV=development

# PostgreSQL（deploy/docker-compose.dev.yml）
DB_HOST=127.0.0.1
DB_PORT=5434
DB_USER=iot
DB_PASSWORD=iot_dev_password
DB_NAME=iot_core
# 首次建表：pnpm build && pnpm migration:run

# 统一 OIDC（Logto / 企业 IdP）
IDP_ISSUER=http://localhost:3001/oidc
IDP_AUDIENCE=
JWT_SECRET=dev-iot-jwt-fallback

# MQTT（deploy/docker-compose.dev.yml → iot-mqtt:1883）
MQTT_ENABLED=true
MQTT_URL=mqtt://127.0.0.1:1883
MQTT_CLIENT_ID=iot-gateway-dev
